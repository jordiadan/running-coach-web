---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname: string;
  navTab?: "plan" | "profile";
}

const { title, description, navTab } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="portal-body">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <main id="main-content" class="portal-main">
      <div class="portal-shell">
        <header class="portal-topbar">
          <div class="portal-brand-group">
            <a class="portal-brand" href="/login">
              Running Coach
            </a>
            <a class="portal-back-link" href="/">Public site</a>
          </div>
          {
            navTab ? (
              <nav class="portal-nav" aria-label="Portal">
                <a
                  class:list={[
                    "portal-nav__link",
                    navTab === "plan" && "portal-nav__link--active",
                  ]}
                  href="/plan"
                  aria-current={navTab === "plan" ? "page" : undefined}
                >
                  Plan
                </a>
                <a
                  class:list={[
                    "portal-nav__link",
                    navTab === "profile" && "portal-nav__link--active",
                  ]}
                  href="/profile"
                  aria-current={navTab === "profile" ? "page" : undefined}
                >
                  Profile
                </a>
              </nav>
            ) : (
              <span class="portal-chip">Portal</span>
            )
          }
        </header>
        <slot />
      </div>
    </main>
  </body>
</html>
