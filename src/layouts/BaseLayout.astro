---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname: string;
}

const { title, description, pathname } = Astro.props;
const isPrivacyPage = pathname === "/privacy";
const topLinkHref = isPrivacyPage ? "/" : "/privacy";
const topLinkLabel = isPrivacyPage ? "Home" : "Privacy";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="brand" href="/">Running Coach</a>
        <nav aria-label="Primary">
          <a class="top-link" href={topLinkHref}>{topLinkLabel}</a>
        </nav>
      </div>
    </header>
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell site-footer__inner">
        <p>Running Coach</p>
        <a href={topLinkHref}>{topLinkLabel}</a>
      </div>
    </footer>
  </body>
</html>
