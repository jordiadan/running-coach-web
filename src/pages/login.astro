---
import PortalLayout from "../layouts/PortalLayout.astro";
---

<PortalLayout
  title="Login | Running Coach"
  description="Sign in to open the Running Coach portal."
  pathname="/login"
>
  <div class="portal-page">
    <section class="portal-screen portal-screen--auth" aria-labelledby="login-title">
      <div class="portal-stage portal-stage--auth">
        <div class="portal-stage__lead">
          <p class="portal-eyebrow">Google sign-in</p>
          <h1 id="login-title" class="portal-title">
            Sign in with Google and move straight into the portal.
          </h1>
          <p class="portal-lede">
            Access should stay light. After sign-in, the portal routes you to the
            next useful step.
          </p>
        </div>

        <div class="portal-stage__panel">
          <div class="portal-card portal-card--auth portal-card--login">
            <p class="portal-mini-chip">Single sign-on</p>
            <p class="portal-card-label">Google account</p>
            <p class="portal-note">
              Use the account linked to the portal. Training setup happens after sign-in.
            </p>

            <div class="portal-button-row">
              <a class="portal-button portal-button--primary portal-google-button" href="/connect">
                <span class="portal-google-mark" aria-hidden="true">G</span>
                Continue with Google
              </a>
            </div>

            <p class="portal-note portal-note--tight">
              Used only for access. The rest of the setup happens inside the portal.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</PortalLayout>
