---
import PortalLayout from "../layouts/PortalLayout.astro";

const weeklyPlan = [
  {
    day: "Tue",
    intensity: "Low",
    intensityTone: "easy",
    type: "Easy run",
    duration: "45 min",
    focus: "Recovery aerobic",
    goal: "Keep the legs moving and add drills without adding fatigue.",
  },
  {
    day: "Thu",
    intensity: "Medium-high",
    intensityTone: "quality",
    type: "Progression run",
    duration: "60 min",
    focus: "Quality session",
    goal: "Raise effort through the run and finish controlled, not emptied out.",
  },
  {
    day: "Sat",
    intensity: "Medium",
    intensityTone: "steady",
    type: "Long run",
    duration: "100 min",
    focus: "Endurance",
    goal: "Stay relaxed and steady so the week builds confidence, not fatigue.",
  },
  {
    day: "Sun",
    intensity: "Low",
    intensityTone: "easy",
    type: "Strength + mobility",
    duration: "30 min",
    focus: "Support work",
    goal: "Keep the body durable and leave the next week easier to start well.",
  },
];
---

<PortalLayout
  title="Plan | Running Coach"
  description="Review the current week in Running Coach."
  pathname="/plan"
  navTab="plan"
>
  <div class="portal-page">
    <section class="portal-screen" aria-labelledby="plan-title">
      <div class="portal-stage">
        <div class="portal-stage__lead">
          <p class="portal-eyebrow">This week</p>
          <h1 id="plan-title" class="portal-title">
            The current week should be the first thing you understand.
          </h1>
          <p class="portal-lede">
            See the week clearly, spot the next key session fast, and understand what
            each day is trying to do.
          </p>
        </div>

        <div class="portal-stage__panel">
          <div class="portal-card portal-card--plan">
            <div class="portal-week-summary">
              <p class="portal-card-label">Objective</p>
              <p class="portal-week-summary__body">
                Build confidence for the long run while keeping one clear quality
                session in the middle of the week.
              </p>
            </div>

            <div class="portal-week-list" aria-label="This week">
              {
                weeklyPlan.map((session) => (
                  <article
                    class:list={[
                      "portal-day-card",
                      session.intensityTone === "quality" && "portal-day-card--quality",
                    ]}
                  >
                    <div class="portal-day-card__top">
                      <p class="portal-card-label">{session.day}</p>
                      <span
                        class:list={[
                          "portal-day-badge",
                          `portal-day-badge--${session.intensityTone}`,
                        ]}
                      >
                        {session.intensity}
                      </span>
                    </div>

                    <h2 class="portal-day-card__title">{session.type}</h2>

                    <div class="portal-day-meta">
                      <span class="portal-day-pill">{session.duration}</span>
                      <span class="portal-day-pill">{session.focus}</span>
                    </div>

                    <div class="portal-day-card__goal">
                      <p class="portal-card-label">Goal</p>
                      <p class="portal-note">{session.goal}</p>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</PortalLayout>
